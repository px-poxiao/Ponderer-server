{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": ["${mod_authors}"],
  "license": "${mod_license}",
  "environment": "client",
  "mixins": [
    "ponderer_client_addon.mixins.json"
  ],
  "entrypoints": {
    "client": [
      "com.ponderer.addon.fabric.PondererAddonFabric"
    ]
  },
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}",
    "java": ">=21",
    "ponderer": "*"
  }
}
